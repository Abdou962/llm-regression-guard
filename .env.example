# ──────────────────────────────────────────────
# LLM Regression Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── API Keys ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Slack Alerting ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Model Configuration ──
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Threshold Configuration ──
# Warning threshold for regression detection (default: 3%)
DIFF_WARNING_THRESHOLD=0.03
# Critical threshold for regression detection (default: 8%)
DIFF_CRITICAL_THRESHOLD=0.08
# Slow drift threshold for 7-run moving average (default: 90%)
SLOW_DRIFT_THRESHOLD=0.90
